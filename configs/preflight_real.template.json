{
  "stages": [
    {
      "name": "real_run_preflight",
      "type": "preflight",
      "args": {
        "input": [
          "data/processed/rubricbench_gold.jsonl",
          "data/processed/rubricbench_queries.jsonl",
          "data/processed/splits/rubricbench_gold_train_seed.jsonl",
          "data/processed/rewardbench_pref.jsonl",
          "data/processed/rewardbench_queries.jsonl",
          "data/processed/judgebench_pref.jsonl",
          "data/processed/judgebench_queries.jsonl",
          "data/processed/rewardbench2_queries.clean.jsonl",
          "data/processed/rewardbench2_multicandidate.clean.jsonl",
          "data/processed/rmbench_queries.jsonl",
          "data/processed/healthbench_queries.jsonl",
          "data/processed/writingbench_queries.jsonl",
          "data/processed/healthbench_hard_queries.jsonl",
          "data/processed/arenahard_queries.jsonl"
        ],
        "providers": [
          "configs/generators.local.jsonl",
          "configs/providers.local.jsonl",
          "configs/verifier.local.jsonl",
          "configs/judge_scorer.local.jsonl"
        ],
        "required_provider": [
          "base",
          "gpt4o",
