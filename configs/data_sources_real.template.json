{
  "local_config_init": {
    "enabled": true,
    "template": "configs/data_sources_real.template.json",
    "output": "configs/data_sources_real.local.json",
    "report_json": "outputs/data_sources/local_config_init.json",
    "report_md": "outputs/data_sources/local_config_init.md",
    "fill_present_sha256": false,
    "update_existing": false,
    "strict": false
  },
  "post_download_local_config_init": {
    "enabled": true,
    "template": "configs/data_sources_real.template.json",
    "output": "configs/data_sources_real.local.json",
    "report_json": "outputs/data_sources/local_config_post_download.json",
    "report_md": "outputs/data_sources/local_config_post_download.md",
    "fill_present_sha256": true,
    "update_existing": true,
    "strict": false
  },
  "pre_normalization_source_report": {
    "enabled": true,
    "config": "configs/data_sources_real.local.json",
    "output_json": "outputs/data_sources/source_report_pre_normalization.json",
    "output_md": "outputs/data_sources/source_report_pre_normalization.md",
    "strict": true
  },
  "source_report": {
    "enabled": true,
    "config": "configs/data_sources_real.local.json",
    "output_json": "outputs/data_sources/source_report.json",
    "output_md": "outputs/data_sources/source_report.md",
    "strict": true
  },
  "datasets": [
    {
      "name": "rubricbench",
      "source": {
        "type": "manual",
        "raw_path": "data/raw/rubricbench_raw.jsonl",
        "official_url": "https://huggingface.co/datasets/DonJoey/rubricbench/resolve/main/data/train-00000-of-00001.parquet",
        "download_enabled": true,
        "require_official_url": true,
        "raw_sha256": "",
        "require_raw_sha256": true,
        "paper_url": "https://arxiv.org/abs/2603.01562",
        "note": "Official RubricBench data is published as DonJoey/rubricbench train parquet on HuggingFace and linked from arXiv:2603.01562v2. Keep raw_sha256 empty in the template until the downloaded JSONL export is audited locally. Required for the hard-gold BSC motivation claim."
      },
      "expected_fields": ["query", "gold_rubrics"],
      "profile": {
        "output": "outputs/data_profiles/rubricbench_schema.json",
        "limit": 100
      },
      "normalizations": [
        {
          "target": "gold",
          "output": "data/processed/rubricbench_gold.jsonl",
          "data_source": "rubricbench",
          "paper_url": "https://arxiv.org/abs/2603.01562",
          "dedupe_query": false,
          "validation": {
            "enabled": true,
            "min_records": 100,
            "min_rubrics_per_query": 1,
            "require_provenance": true,
            "required_data_source": ["rubricbench"],
            "forbidden_data_source": ["toy", "proxy"],
            "output_json": "outputs/data_validation/rubricbench_gold.json",
            "output_md": "outputs/data_validation/rubricbench_gold.md",
            "strict": true
          },
          "split": {
            "enabled": true,
            "output_dir": "data/processed/splits",
            "output_prefix": "rubricbench_gold_",
            "manifest": "outputs/data_splits/rubricbench_gold_split.json",
            "splits": ["train_seed:500", "dev:150", "test_main:497"],
            "group_key": "query",
            "stratify_key": "data_source",
            "gold_type": "human_gold",
            "main_eval_split": ["test_main"],
            "seed": 13,
            "outputs": [
              "data/processed/splits/rubricbench_gold_train_seed.jsonl",
              "data/processed/splits/rubricbench_gold_dev.jsonl",
              "data/processed/splits/rubricbench_gold_test_main.jsonl"
            ]
          }
        },
        {
          "target": "query_pool",
          "output": "data/processed/rubricbench_queries.jsonl",
          "data_source": "rubricbench",
          "dedupe_query": false,
          "validation": {
            "enabled": true,
            "min_records": 100,
            "require_provenance": true,
            "required_data_source": ["rubricbench"],
            "forbidden_data_source": ["toy", "proxy"],
            "output_json": "outputs/data_validation/rubricbench_queries.json",
            "output_md": "outputs/data_validation/rubricbench_queries.md",
            "strict": true
          }
        }
      ]
    },
    {
