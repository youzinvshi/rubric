            "enabled": true,
            "output_dir": "data/processed/splits",
            "output_prefix": "rewardbench_pref_",
            "manifest": "outputs/data_splits/rewardbench_pref_split.json",
            "splits": ["sft_proxy_train:0.6", "dev:0.2", "downstream_holdout:rest"],
            "group_key": "query",
            "stratify_key": "data_source",
            "gold_type": "proxy_teacher",
            "main_eval_split": [],
            "seed": 13,
            "outputs": [
              "data/processed/splits/rewardbench_pref_sft_proxy_train.jsonl",
              "data/processed/splits/rewardbench_pref_dev.jsonl",
              "data/processed/splits/rewardbench_pref_downstream_holdout.jsonl"
            ]
          }
        },
        {
          "target": "query_pool",
          "output": "data/processed/rewardbench_queries.jsonl",
          "data_source": "rewardbench",
          "dedupe_query": true
        }
      ]
