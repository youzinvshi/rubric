    {
      "name": "rewardbench",
      "source": {
        "type": "hf",
        "preset": "rewardbench",
        "output": "data/raw/rewardbench_filtered.jsonl"
      },
      "expected_fields": ["prompt", "chosen", "rejected"],
      "profile": {
        "output": "outputs/data_profiles/rewardbench_schema.json",
        "limit": 100
      },
      "normalizations": [
        {
          "target": "preference",
          "output": "data/processed/rewardbench_pref.jsonl",
          "data_source": "rewardbench",
