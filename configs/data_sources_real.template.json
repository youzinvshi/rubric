            "forbidden_data_source": ["toy", "proxy"],
            "output_json": "outputs/data_validation/researchrubrics_gold.json",
            "output_md": "outputs/data_validation/researchrubrics_gold.md",
            "strict": true
          },
          "split": {
            "enabled": true,
            "output_dir": "data/processed/splits",
            "output_prefix": "researchrubrics_gold_",
            "manifest": "outputs/data_splits/researchrubrics_gold_split.json",
            "splits": ["train_seed:60", "dev_test:rest"],
            "group_key": "query",
            "stratify_key": "data_source",
            "gold_type": "human_gold",
            "main_eval_split": [],
            "seed": 13,
            "outputs": [
              "data/processed/splits/researchrubrics_gold_train_seed.jsonl",
              "data/processed/splits/researchrubrics_gold_dev_test.jsonl"
            ]
          }
        },
        {
          "target": "query_pool",
          "output": "data/processed/researchrubrics_queries.jsonl",
          "data_source": "researchrubrics",
          "dedupe_query": true,
          "validation": {
            "enabled": true,
            "min_records": 100,
            "require_provenance": true,
            "required_data_source": ["researchrubrics"],
            "forbidden_data_source": ["toy", "proxy"],
            "output_json": "outputs/data_validation/researchrubrics_queries.json",
            "output_md": "outputs/data_validation/researchrubrics_queries.md",
            "strict": true
          }
