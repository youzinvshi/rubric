{
  "stages": [
    {
      "name": "init_data_source_local_config",
      "type": "init_data_source_config",
      "args": {
        "template": "configs/data_sources_real.template.json",
        "output": "configs/data_sources_real.local.json",
        "report_json": "outputs/data_sources/local_config_init_researchrubrics.json",
        "report_md": "outputs/data_sources/local_config_init_researchrubrics.md",
        "required_dataset": [
          "researchrubrics"
        ],
        "fill_present_sha256": false,
        "update_existing": false,
        "strict": false
      }
    },
    {
      "name": "download_researchrubrics",
      "type": "download",
      "args": {
        "url": "https://huggingface.co/datasets/ScaleAI/researchrubrics/resolve/main/processed_data.jsonl",
        "output": "data/raw/researchrubrics_raw.jsonl"
      }
    },
    {
      "name": "init_data_source_local_config_post_download",
      "type": "init_data_source_config",
      "args": {
        "template": "configs/data_sources_real.template.json",
        "output": "configs/data_sources_real.local.json",
        "report_json": "outputs/data_sources/local_config_post_download_researchrubrics.json",
        "report_md": "outputs/data_sources/local_config_post_download_researchrubrics.md",
        "required_dataset": [
          "researchrubrics"
        ],
        "fill_present_sha256": true,
        "update_existing": true,
        "strict": false
      }
    },
    {
      "name": "data_source_report_pre_normalization",
      "type": "data_source_report",
      "args": {
        "config": "configs/data_sources_real.local.json",
        "output_json": "outputs/data_sources/source_report_pre_normalization_researchrubrics.json",
        "output_md": "outputs/data_sources/source_report_pre_normalization_researchrubrics.md",
        "required_dataset": [
          "researchrubrics"
        ],
        "strict": true
      }
    },
    {
      "name": "profile_researchrubrics",
      "type": "profile_data",
      "args": {
        "input": "data/raw/researchrubrics_raw.jsonl",
        "output": "outputs/data_profiles/researchrubrics_schema.json",
        "limit": 100
      }
    },
    {
      "name": "normalize_researchrubrics_gold_1",
      "type": "normalize",
      "args": {
        "input": "data/raw/researchrubrics_raw.jsonl",
        "output": "data/processed/researchrubrics_gold.jsonl",
        "target": "gold",
        "data_source": "researchrubrics",
        "source_url": "https://huggingface.co/datasets/ScaleAI/researchrubrics/resolve/main/processed_data.jsonl",
        "paper_url": "https://arxiv.org/abs/2511.07685",
        "dedupe_query": true
      }
    },
    {
      "name": "validate_researchrubrics_gold_1",
      "type": "validate_gold",
      "args": {
        "input": "data/processed/researchrubrics_gold.jsonl",
        "target": "gold",
        "output_json": "outputs/data_validation/researchrubrics_gold.json",
        "output_md": "outputs/data_validation/researchrubrics_gold.md",
        "min_records": 100,
        "min_rubrics_per_query": 1,
        "require_provenance": true,
        "strict": true,
        "required_data_source": [
          "researchrubrics"
        ],
        "forbidden_data_source": [
          "toy",
          "proxy"
        ],
        "required_provenance": [
          "paper_url=https://arxiv.org/abs/2511.07685",
          "source_url=https://huggingface.co/datasets/ScaleAI/researchrubrics/resolve/main/processed_data.jsonl"
        ]
      }
    },
    {
      "name": "normalize_researchrubrics_query_pool_2",
      "type": "normalize",
      "args": {
        "input": "data/raw/researchrubrics_raw.jsonl",
        "output": "data/processed/researchrubrics_queries.jsonl",
        "target": "query_pool",
        "data_source": "researchrubrics",
        "source_url": "https://huggingface.co/datasets/ScaleAI/researchrubrics/resolve/main/processed_data.jsonl",
        "paper_url": "https://arxiv.org/abs/2511.07685",
        "dedupe_query": true
      }
    },
    {
      "name": "validate_researchrubrics_query_pool_2",
      "type": "validate_gold",
      "args": {
        "input": "data/processed/researchrubrics_queries.jsonl",
        "target": "query_pool",
        "output_json": "outputs/data_validation/researchrubrics_queries.json",
        "output_md": "outputs/data_validation/researchrubrics_queries.md",
        "min_records": 100,
        "min_rubrics_per_query": 1,
        "require_provenance": true,
        "strict": true,
        "required_data_source": [
          "researchrubrics"
        ],
        "forbidden_data_source": [
          "toy",
          "proxy"
        ],
        "required_provenance": [
          "paper_url=https://arxiv.org/abs/2511.07685",
          "source_url=https://huggingface.co/datasets/ScaleAI/researchrubrics/resolve/main/processed_data.jsonl"
        ]
      }
    },
    {
      "name": "data_source_report",
      "type": "data_source_report",
      "args": {
        "config": "configs/data_sources_real.local.json",
        "output_json": "outputs/data_sources/source_report_researchrubrics.json",
        "output_md": "outputs/data_sources/source_report_researchrubrics.md",
        "required_dataset": [
          "researchrubrics"
        ],
        "strict": true
      }
    }
  ]
}
